# Copy to `.env` for local integration work.

# Common
SQLDBAGENT_ENV=dev
SQLDBAGENT_LOG_LEVEL=INFO
SQLDBAGENT_PROFILING__DEFAULT_SAMPLE_SIZE=5
SQLDBAGENT_PROFILING__MAX_SAMPLE_SIZE=50
# Set this to `postgres_demo` when you want the local demo database to be the
# default inspected datasource for the CLI or LangGraph runtime.
SQLDBAGENT_DEFAULT_DATASOURCE=postgres
# Optional datasource aliases encoded as JSON, for example:
# SQLDBAGENT_DATASOURCE_ALIASES={"demo":"postgres_demo","pg":"postgres"}
SQLDBAGENT_DATASOURCE_ALIASES={}
SQLDBAGENT_ARTIFACTS__ROOT_DIR=var/sqldbagent
SQLDBAGENT_ARTIFACTS__SNAPSHOTS_DIR=snapshots
SQLDBAGENT_ARTIFACTS__DOCUMENTS_DIR=documents
SQLDBAGENT_ARTIFACTS__DIAGRAMS_DIR=diagrams
SQLDBAGENT_ARTIFACTS__EMBEDDINGS_CACHE_DIR=embeddings-cache
SQLDBAGENT_ARTIFACTS__VECTORSTORES_DIR=vectorstores
SQLDBAGENT_AGENT_NAME=sqldbagent
SQLDBAGENT_AGENT_INCLUDE_LATEST_SNAPSHOT_CONTEXT=true
SQLDBAGENT_AGENT_MAX_MODEL_CALLS_PER_RUN=8
SQLDBAGENT_AGENT_MAX_TOOL_CALLS_PER_RUN=24
SQLDBAGENT_AGENT_ENABLE_TODO_MIDDLEWARE=true
SQLDBAGENT_AGENT_ENABLE_HUMAN_IN_THE_LOOP=false
SQLDBAGENT_AGENT_ENABLE_SUMMARIZATION_MIDDLEWARE=false
SQLDBAGENT_AGENT_SUMMARIZATION_TRIGGER_FRACTION=0.90
SQLDBAGENT_AGENT_SUMMARIZATION_KEEP_MESSAGES=20
SQLDBAGENT_AGENT_TOOL_CALL_DIGEST_LIMIT=10
SQLDBAGENT_AGENT_CHECKPOINT_BACKEND=postgres
SQLDBAGENT_AGENT_CHECKPOINT_AUTO_SETUP=true
SQLDBAGENT_AGENT_CHECKPOINT_PIPELINE=false
SQLDBAGENT_EMBEDDINGS__PROVIDER=openai
SQLDBAGENT_EMBEDDINGS__MODEL=text-embedding-3-large
SQLDBAGENT_EMBEDDINGS__CACHE_QUERY_EMBEDDINGS=true
SQLDBAGENT_RETRIEVAL__QDRANT_URL=http://127.0.0.1:6333
SQLDBAGENT_RETRIEVAL__QDRANT_GRPC_PORT=6334
SQLDBAGENT_RETRIEVAL__QDRANT_PREFER_GRPC=false
SQLDBAGENT_RETRIEVAL__COLLECTION_PREFIX=sqldbagent
SQLDBAGENT_RETRIEVAL__DEFAULT_TOP_K=6
SQLDBAGENT_RETRIEVAL__DEFAULT_FETCH_K=24
SQLDBAGENT_RETRIEVAL__USE_MMR=true
SQLDBAGENT_RETRIEVAL__CREATE_PAYLOAD_INDEXES=true

# Postgres integration target.
# In local demos this Postgres can also be the default datasource, but in real
# deployments the checkpoint database should usually be separate from the
# inspected application databases.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=sqldbagent
POSTGRES_USER=sqldbagent
POSTGRES_PASSWORD=sqldbagent
# Optional explicit checkpoint database override.
# In production this should usually point at a dedicated Postgres database.
# SQLDBAGENT_AGENT_CHECKPOINT_POSTGRES_URL=postgresql+psycopg://sqldbagent:sqldbagent@127.0.0.1:5432/sqldbagent

# MSSQL integration target
MSSQL_HOST=127.0.0.1
MSSQL_PORT=1433
MSSQL_DATABASE=sqldbagent
MSSQL_USER=sa
MSSQL_PASSWORD=YourStrong!Passw0rd

# Postgres demo datasource. This is the app-style database you can inspect,
# profile, snapshot, and query during local demos.
POSTGRES_DEMO_HOST=127.0.0.1
POSTGRES_DEMO_PORT=5433
POSTGRES_DEMO_DB=sqldbagent_demo
POSTGRES_DEMO_USER=sqldbagent
POSTGRES_DEMO_PASSWORD=sqldbagent

# SQLite smoke target
SQLITE_PATH=.local/test/sqldbagent.db

# Qdrant integration target
QDRANT_PORT=6333
QDRANT_URL=http://127.0.0.1:6333
QDRANT_GRPC_PORT=6334

# Optional LLM provider config is intentionally omitted from this example.
# Keep provider keys in your local `.env` only.
